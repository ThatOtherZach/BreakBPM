modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8090
externalPort = 3002

[[ports]]
localPort = 8093
externalPort = 3003

[[ports]]
localPort = 8094
externalPort = 4200

[[ports]]
localPort = 8095
externalPort = 5000

[[ports]]
localPort = 8096
externalPort = 5173

[[ports]]
localPort = 8097
externalPort = 6000

[[ports]]
localPort = 21323
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BREAKBPM_CARD_PAYMENTS_ENABLED = "false"
BREAKBPM_CRYPTO_PAYMENTS_ENABLED = "true"
BREAKBPM_CRYPTO_NETWORK = "base"
BREAKBPM_CRYPTO_RECEIVING_ADDRESS = "0xC300A97f4ce2f9D4B02106045374c4C5eDb349af"
BREAKBPM_STORE_URL = "https://www.saymservices.com/store/p/breakbpm-14-day-pass"
BREAKBPM_BANNED_WORDS = "fuck, ass, bitch, cunt, faggot, nigger, Palestine, gaza, jew, Zionist, Nazi, Hitler, reich, gay"
